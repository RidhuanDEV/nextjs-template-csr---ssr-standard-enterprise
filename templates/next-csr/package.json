{
  "name": "next-csr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cli:build": "tsc -p cli/tsconfig.json",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"cli/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"cli/**/*.{ts,tsx}\" --fix --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"cli/**/*.{ts,tsx,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"cli/**/*.{ts,tsx,json,md}\" \"*.{json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "prepare": "npm run cli:build && husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "commander": "^14.0.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^13.3.0",
    "next": "16.1.6",
    "pluralize": "^8.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}

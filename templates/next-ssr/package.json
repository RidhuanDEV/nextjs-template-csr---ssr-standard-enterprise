{
  "name": "next-ssr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cli:build": "tsc -p cli/tsconfig.json",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"cli/**/*.{ts,tsx}\" \"vitest.config.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"cli/**/*.{ts,tsx}\" \"vitest.config.ts\" --fix --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"cli/**/*.{ts,tsx,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"cli/**/*.{ts,tsx,json,md}\" \"*.{json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "prepare": "npm run cli:build && husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.4",
    "commander": "^14.0.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.3.0",
    "ioredis": "^5.10.0",
    "jose": "^6.2.1",
    "mariadb": "^3.5.2",
    "next": "16.1.6",
    "pino": "^10.3.1",
    "pluralize": "^8.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.18"
  }
}
